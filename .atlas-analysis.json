  "keyFeatures": [
    "Equipment inventory management with status tracking",
    "Police fleet and vehicle administration",
    "Camera and bodycam tracking system",
    "Role-based access control with Spatie permissions",
    "Real-time command center (CECOCO) with live mapping",
    "Dependency hierarchy management (departments, divisions, stations)",
    "Audit logging and historical tracking",
    "Advanced search and filtering capabilities",
    "Excel export functionality for reports",
    "Task management with recurring task generation"
  ],
  "publicApiSurface": [
    "POST /login - User authentication",
    "POST /logout - User logout",
    "GET /home - Main dashboard",
    "Resource /equipos - Equipment CRUD operations",
    "Resource /flota - Fleet management endpoints",
    "Resource /camaras - Camera management",
    "Resource /bodycams - Bodycam tracking",
    "Resource /usuarios - User administration",
    "Resource /roles - Role management",
    "Resource /dependencias - Dependency hierarchy",
    "GET /indexMapaCecocoEnVivo - Live CECOCO map",
    "POST /get-moviles-json - Retrieve mobile units",
    "POST /get-equipos-funcionales-json - Retrieve functional equipment",
    "GET /export-equipos - Export equipment to Excel",
    "GET /auditoria - Audit log access",
    "Resource /tareas - Task management",
    "GET /api/plano-edificio/devices - Building floor plan devices"
  ]
